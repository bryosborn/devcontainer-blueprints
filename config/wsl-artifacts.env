# WSL bootstrap artifact defaults.

WSL_ARTIFACT_ROOT=artifacts/wsl

# Match the VS Code version used for the container-side server unless overridden.
WSL_VSCODE_VERSION=${BASE_VSCODE_VERSION:-latest}
WSL_VSCODE_COMMIT=${BASE_VSCODE_COMMIT:-}
WSL_VSCODE_QUALITY=${BASE_VSCODE_QUALITY:-stable}

# Windows client metadata platform used to resolve product version -> commit.
WSL_CLIENT_PLATFORM=win32-x64-archive

# Linux server payloads staged for WSL. Space-delimited.
WSL_SERVER_PLATFORMS="server-linux-x64"

# Windows-side VS Code extensions needed for WSL and Dev Containers bootstrap. Space-delimited.
WSL_EXTENSIONS="ms-vscode-remote.remote-wsl ms-vscode-remote.remote-containers"

# Build and save the Dev Containers bootstrap container image used by
# "Clone Repository in Container Volume".
WSL_PREFETCH_DEVCONTAINERS_BOOTSTRAP_IMAGE=true
WSL_DEVCONTAINERS_BOOTSTRAP_EXTENSION=ms-vscode-remote.remote-containers
WSL_DEVCONTAINERS_BOOTSTRAP_IMAGE_NAME=vsc-volume-bootstrap
