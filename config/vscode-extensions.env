# VS Code extension prefetch defaults.

# Stable only for first implementation.
VSCODE_EXTENSION_QUALITY=stable

# Container platform for extension VSIX selection.
# Supported initial values:
#   linux-x64
#   linux-arm64
VSCODE_EXTENSION_TARGET_PLATFORM=linux-x64

# Match the VS Code Server artifact generated by the server prefetch task.
# This JSON should contain productVersion and commit.
VSCODE_SERVER_METADATA_JSON=artifacts/vscode-server/current-stable-server-linux-x64.json

# Extension list.
VSCODE_EXTENSIONS_FILE=config/vscode-extensions.txt

# Artifact root.
VSCODE_EXTENSIONS_ARTIFACT_ROOT=artifacts/vscode-extensions

# Remote user inside the container.
VSCODE_EXTENSIONS_REMOTE_USER=vscode

# Install only extensions that can run in the container by default.
VSCODE_EXTENSIONS_CONTAINER_ONLY=true

# Do not include Marketplace pre-release extension versions in first implementation.
VSCODE_EXTENSIONS_INCLUDE_PRERELEASE=false
