# Example Nexus Docker registry config.
# Copy this file and edit it for the actual company registry.

REGISTRY=nexus.company.com
IMAGE_NAMESPACE=repository/docker-dev/devcontainers
UPSTREAM_NAMESPACE=repository/docker-dev/upstream/devcontainers
IMAGE_VERSION=0.1.0

UPSTREAM_BASE_IMAGE=mcr.microsoft.com/devcontainers/base:ubuntu
LOCAL_UPSTREAM_BASE_IMAGE=${REGISTRY}/${UPSTREAM_NAMESPACE}/base:ubuntu

DEV_BASE_IMAGE=${REGISTRY}/${IMAGE_NAMESPACE}/dev-base:${IMAGE_VERSION}
