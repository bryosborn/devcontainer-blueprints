REGISTRY=devcontainers
BASE_IMAGE_NAME=base-dod
BASE_IMAGE_VERSION=0.1.0
BASE_IMAGE=${REGISTRY}/${BASE_IMAGE_NAME}:${BASE_IMAGE_VERSION}

UPSTREAM_BASE_IMAGE=mcr.microsoft.com/devcontainers/base:3.0.1-ubuntu22.04

DOD_FEATURE_REF=ghcr.io/devcontainers/features/docker-outside-of-docker
DOD_FEATURE_VERSION=1.10.0
DOD_DOCKER_CE_CLI_VERSION=29.5.3-1
DOD_DOCKER_COMPOSE_VERSION=2.40.3
DOD_DOCKER_BUILDX_VERSION=0.34.1-1
DOD_FEATURE_MOBY=false
DOD_FEATURE_DOCKER_DASH_COMPOSE_VERSION=v2
DOD_FEATURE_INSTALL_DOCKER_BUILDX=true
DOD_FEATURE_INSTALL_DOCKER_COMPOSE_SWITCH=false
DOD_COMPOSE_SWITCH_VERSION=1.0.5
DOD_FEATURE_ENABLE_NONROOT_DOCKER=true

BASE_VSCODE_TEMPLATE_ID=base-vscode
BASE_VSCODE_IMAGE_NAME=base-vscode
BASE_VSCODE_IMAGE_VERSION=0.1.0
BASE_VSCODE_IMAGE=${REGISTRY}/${BASE_VSCODE_IMAGE_NAME}:${BASE_VSCODE_IMAGE_VERSION}
BASE_VSCODE_VERSION=1.124.2
# Optional exact override. Leave empty to use BASE_VSCODE_VERSION.
BASE_VSCODE_COMMIT=
BASE_VSCODE_QUALITY=stable
BASE_VSCODE_CLIENT_PLATFORM=linux-x64
BASE_VSCODE_SERVER_PLATFORM=server-linux-x64
BASE_VSCODE_REMOTE_USER=vscode
BASE_VSCODE_ARTIFACT_ROOT=artifacts/vscode-server

APT_ARTIFACT_ROOT=artifacts/apt
APT_PACKAGE_LIST=src/apt-artifacts/apt-packages.txt
APT_PREFETCH_IMAGE=${UPSTREAM_BASE_IMAGE}
APT_INCLUDE_DEADSNAKES=true
